{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Active Test",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-Command",
                "$files = Get-ChildItem \"${workspaceFolder}\\src\" -Recurse -Filter *.cpp | ForEach-Object { $_.FullName }; g++ \"${file}\" $files -o \"${workspaceFolder}\\tests\\test.exe\"; if ($?) { & \"${workspaceFolder}\\tests\\test.exe\" }"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Build Practice File",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-Command",
                "g++ \"${file}\" -o \"${fileDirname}\\temp.exe\"; if ($?) { & \"${fileDirname}\\temp.exe\" }"
            ],
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}